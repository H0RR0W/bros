# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cybersim:password@postgres:5432/cybersim
POSTGRES_PASSWORD=password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
SCENARIO_CACHE_TTL=86400

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-secure-random-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── DeepSeek AI ───────────────────────────────────────────────────────────────
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=30

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://localhost

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://localhost/api
NEXT_PUBLIC_WS_URL=wss://localhost/ws

# ── Admin seed user ───────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@cybersim.local
FIRST_ADMIN_PASSWORD=Admin_secure_pass123!
